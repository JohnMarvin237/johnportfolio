// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION MODEL
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // Hash bcrypt
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

// ============================================
// PORTFOLIO CONTENT MODELS
// ============================================

model Project {
  id            String    @id @default(cuid())
  title         String
  titleFr       String?   @map("title_fr")
  titleEn       String?   @map("title_en")
  description   String    @db.Text
  descriptionFr String?   @db.Text @map("description_fr")
  descriptionEn String?   @db.Text @map("description_en")
  longDesc      String?   @db.Text
  longDescFr    String?   @db.Text @map("longDesc_fr")
  longDescEn    String?   @db.Text @map("longDesc_en")
  technologies  String[]
  imageUrl      String?
  demoUrl       String?
  githubUrl     String?
  featured      Boolean   @default(false)
  order         Int       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  organization  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([featured])
  @@index([order])
  @@map("projects")
}

model Experience {
  id              String    @id @default(cuid())
  title           String
  titleFr         String?   @map("title_fr")
  titleEn         String?   @map("title_en")
  company         String
  companyUrl      String?
  location        String
  startDate       DateTime
  endDate         DateTime?
  current         Boolean   @default(false)
  description     String    @db.Text
  descriptionFr   String?   @db.Text @map("description_fr")
  descriptionEn   String?   @db.Text @map("description_en")
  achievements    String[]
  achievementsFr  String[]  @map("achievements_fr")
  achievementsEn  String[]  @map("achievements_en")
  technologies    String[]
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([current])
  @@index([order])
  @@map("experiences")
}

model Education {
  id            String    @id @default(cuid())
  degree        String
  degreeFr      String?   @map("degree_fr")
  degreeEn      String?   @map("degree_en")
  institution   String
  location      String
  field         String?
  fieldFr       String?   @map("field_fr")
  fieldEn       String?   @map("field_en")
  startDate     DateTime
  endDate       DateTime?
  current       Boolean   @default(false)
  description   String?   @db.Text
  descriptionFr String?   @db.Text @map("description_fr")
  descriptionEn String?   @db.Text @map("description_en")
  gpa           String?
  note          String?
  noteFr        String?   @map("note_fr")
  noteEn        String?   @map("note_en")
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([current])
  @@index([order])
  @@map("education")
}

model Certification {
  id            String    @id @default(cuid())
  title         String
  titleFr       String?   @map("title_fr")
  titleEn       String?   @map("title_en")
  issuer        String
  issueDate     DateTime?
  expiryDate    DateTime?
  credentialId  String?
  credentialUrl String?
  description   String?   @db.Text
  descriptionFr String?   @db.Text @map("description_fr")
  descriptionEn String?   @db.Text @map("description_en")
  skills        String[]
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([order])
  @@map("certifications")
}

model Volunteer {
  id            String    @id @default(cuid())
  title         String
  titleFr       String?   @map("title_fr")
  titleEn       String?   @map("title_en")
  organization  String
  location      String?
  startDate     DateTime
  endDate       DateTime?
  current       Boolean   @default(false)
  description   String    @db.Text
  descriptionFr String?   @db.Text @map("description_fr")
  descriptionEn String?   @db.Text @map("description_en")
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([current])
  @@index([order])
  @@map("volunteer")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@map("contact_messages")
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("site_settings")
}
